<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>

    <style>
        * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', sans-serif;
}

body {
    background: linear-gradient(135deg, #0f172a, #1e293b);
    min-height: 100vh;
}

/* Header */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 40px;
    color: white;
}

.header h1 {
    font-size: 24px;
    letter-spacing: 1px;
}
/* Add Button */
.addbtn button {
    padding: 10px 18px;
    border: none;
    border-radius: 10px;
    background: rgba(255,255,255,0.2);
    color: white;
    font-weight: bold;
    cursor: pointer;
    backdrop-filter: blur(10px);
    transition: 0.3s;
}

.addbtn button:hover {
    background: rgba(255,255,255,0.35);
    transform: translateY(-2px);
}

/* Grid */
.container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 25px;
    padding: 30px;
}

/* Card */
.card {
    background: #ffffff;
    border-radius: 14px;
    padding: 20px;
    text-align: center;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    transition: all 0.3s ease;
}

.card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.2);
}

/* Avatar */
.card img {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #667eea;
    margin-bottom: 10px;
}

/* Info */
.info p {
    margin: 6px 0;
    font-size: 14px;
    color: #444;
}

.info strong {
    color: #222;
}

/* Buttons (applies to both forms) */
.info form {
    margin-top: 8px;
}

/* Base button */
.info form button {
    width: 100%;
    padding: 8px;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    cursor: pointer;
    transition: 0.3s;
}

/* Edit button */
.info form:first-of-type button {
    background: #667eea;
    color: white;
}

.info form:first-of-type button:hover {
    background: #5a67d8;
    transform: translateY(-2px);
}

/* Delete button */
.info form:last-of-type button {
    background: #e63946;
    color: white;
}

.info form:last-of-type button:hover {
    background: #c82333;
    transform: translateY(-2px);
}

/* Responsive */
@media(max-width: 500px) {
    .header {
        flex-direction: column;
        gap: 10px;
    }
}
    </style>
   
</head>

<body>

    <!-- Header -->
    <div class="header">
        <h1>User Dashboard</h1>

        <form method="GET" action="/user/add" class="addbtn">
            <button type="submit">+ Add User</button>
        </form>
    </div>

    <!-- Cards -->
    <div class="container">
        <% for (let user of result) { %>
            <div class="card">

                <img src="<%= user.avatar %>" alt="avatar">

                <div class="info">
                    <p><strong>ID:</strong> <%= user.id %></p>
                    <p><strong>Email:</strong> <%= user.email %></p>
                    <p><strong>Username:</strong> <%= user.username %></p>

                    <form method="GET" action="/user/<%= user.id %>/edit">
                        <button type="submit">Edit</button>
                       
                       

                    </form>
                     <form method="GET" action="/user/<%= user.id %>/delete">
                        <button type="submit">DELETE</button>
                       

                    </form>

                      
                </div>

            </div>
        <% } %>
    </div>

</body>
</html>