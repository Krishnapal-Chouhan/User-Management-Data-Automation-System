<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit User</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6f8;
        }

        .card {
            background: #fff;
            margin: 50px auto;
            width: 350px;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            text-align: center;
        }

        .card img {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 15px;
        }

        h2 {
            margin-bottom: 15px;
        }

        .form-group {
            text-align: left;
            margin-bottom: 12px;
        }

        label {
            font-size: 13px;
            font-weight: bold;
        }

        input {
            width: 100%;
            padding: 8px;
            margin-top: 4px;
            border-radius: 6px;
            border: 1px solid #ccc;
        }

        button {
            margin-top: 15px;
            padding: 10px;
            width: 100%;
            border: none;
            background: #2c7be5;
            color: white;
            border-radius: 6px;
            cursor: pointer;
        }

        button:hover {
            background: #1a5edb;
        }
    </style>
</head>

<body>

<div class="card">

    <!-- Avatar -->
    <img src="<%= user.avatar %>" alt="avatar">

    <h2>Edit <%= user.username %></h2>

    <form method="POST" action="/user/<%= user.id %>?_method=PATCH">

        <div class="form-group">
            <label>Username</label>
            <input type="text" name="username" value="<%= user.username %>" required>
        </div>

        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" value="<%= user.email %>" required>
        </div>

        <div class="form-group">
            <label>Password (required to update)</label>
            <input type="password" name="password" placeholder="Enter password" required>
        </div>

        <button type="submit">Update User</button>

    </form>

</div>

</body>
</html>